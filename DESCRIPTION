Package: fbnardl
Type: Package
Title: Fourier Bootstrap Nonlinear Autoregressive Distributed Lag Model
Version: 1.0.1
Authors@R: c(
    person("Muhammad", "Alkhalaf", 
           email = "muhammedalkhalaf@gmail.com",
           role = c("aut", "cre", "cph"),
           comment = c(ORCID = "0009-0002-2677-9246")),
    person("Merwan", "Roudane",
           role = "ctb",
