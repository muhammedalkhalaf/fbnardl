> # Estimate FBNARDL model (bootstrap critical values)
> model_fbnardl <- fbnardl(
+   inflation ~ oil_price + gdp_growth,
+   data = oil_inflation,
+   decompose = "oil_price",
+   type = "fbnardl",
+   maxlag = 4,
+   reps = 999
+ )

